# ShopCart Environment Variables Template
# Copy this to .env and fill in YOUR values from the accounts created in SETUP_GUIDE.md

# ============================================
# SANITY CMS Configuration
# ============================================
# Get these from: https://www.sanity.io/manage/
NEXT_PUBLIC_SANITY_PROJECT_ID=YOUR_SANITY_PROJECT_ID_HERE
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-11-09
SANITY_API_TOKEN=YOUR_SANITY_API_TOKEN_HERE
SANITY_API_READ_TOKEN=YOUR_SANITY_API_READ_TOKEN_HERE

# ============================================
# CLERK Authentication
# ============================================
# Get these from: https://clerk.com/docs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_YOUR_PUBLISHABLE_KEY_HERE
CLERK_SECRET_KEY=sk_YOUR_SECRET_KEY_HERE

# Clerk URL Configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================
# STRIPE Payment Processing
# ============================================
# Get these from: https://stripe.com/docs/payments
# Use TEST keys (pk_test_*, sk_test_*) for development
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ============================================
# Your Store Information
# ============================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_NAME=Your Store Name
NEXT_PUBLIC_COMPANY_EMAIL=your-email@example.com
NEXT_PUBLIC_COMPANY_PHONE=+1 (555) 000-0000
NEXT_PUBLIC_COMPANY_ADDRESS=Your Store Address
NEXT_PUBLIC_COMPANY_CITY=Your City, State ZIP
NEXT_PUBLIC_COMPANY_BUSINESS_HOURS_WEEKDAY=Monday - Friday: 9AM - 6PM
NEXT_PUBLIC_COMPANY_BUSINESS_HOURS_WEEKEND=Saturday - Sunday: 10AM - 4PM
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourstore.com
NEXT_PUBLIC_SALES_EMAIL=sales@yourstore.com
NEXT_PUBLIC_CONTACT_RESPONSE_TIME=We reply within 24 hours
NEXT_PUBLIC_QUICK_RESPONSE_TIME=2-4 hours during business hours

# ============================================
# Social Media Links
# ============================================
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/yourstore
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/yourstore
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourstore
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/yourstore

# ============================================
# Store Policies & Info
# ============================================
NEXT_PUBLIC_COMPANY_DESCRIPTION=Your store description here
NEXT_PUBLIC_COPYRIGHT_TEXT=© 2025 Your Store Name. All rights reserved.
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy
NEXT_PUBLIC_TERMS_URL=/terms
NEXT_PUBLIC_PAID_VERSION=https://buymeacoffee.com/yourprofile

# ============================================
# Admin Configuration
# ============================================
NEXT_PUBLIC_ADMIN_EMAIL=your-admin-email@example.com
TAX_AMOUNT=0.00
