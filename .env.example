# Base email: your_email@gmail.com
# COPY THIS FILE TO .env AND FILL IN YOUR ACTUAL VALUES

# NEXT_PUBLIC_BASE_URL=https://shopcartpro.reactbd.org
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_PAID_VERION=https://buymeacoffee.com/reactbd
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-11-09
SANITY_API_TOKEN=your_sanity_api_token_here
SANITY_API_READ_TOKEN=your_sanity_read_token_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk URL Configuration (deprecated - use forceRedirectUrl/fallbackRedirectUrl in components instead)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Admin Configuration
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourstore.com

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# PesaPal Payment Configuration
# Get credentials from: https://www.pesapal.com/developers
NEXT_PUBLIC_PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key_here
NEXT_PUBLIC_PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret_here
PESAPAL_API_KEY=your_pesapal_api_key_here
PESAPAL_API_SECRET=your_pesapal_api_secret_here
NEXT_PUBLIC_PESAPAL_CURRENCY=KES
NEXT_PUBLIC_PESAPAL_CALLBACK_URL=http://localhost:3000/api/pesapal/callback

# Contact Information
NEXT_PUBLIC_COMPANY_NAME=Your Store Name
NEXT_PUBLIC_COMPANY_EMAIL=your-email@yourstore.com
NEXT_PUBLIC_COMPANY_PHONE=+1 (YOUR) NUMBER-HERE
NEXT_PUBLIC_COMPANY_ADDRESS=Your Business Address
NEXT_PUBLIC_COMPANY_CITY=Your City, State 12345, USA
NEXT_PUBLIC_COMPANY_BUSINESS_HOURS_WEEKDAY=Monday - Friday: 9AM - 6PM
NEXT_PUBLIC_COMPANY_BUSINESS_HOURS_WEEKEND=Saturday - Sunday: 10AM - 4PM
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourstore.com
NEXT_PUBLIC_SALES_EMAIL=sales@yourstore.com
NEXT_PUBLIC_CONTACT_RESPONSE_TIME=We reply within 24 hours
NEXT_PUBLIC_QUICK_RESPONSE_TIME=2-4 hours during business hours

# Social Media Links (Optional)
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/yourstore
NEXT_PUBLIC_TWITTER_URL=https://www.twitter.com/yourstore
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourstore
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/yourstore

# Additional Settings
NEXT_PUBLIC_COMPANY_DESCRIPTION=Discover amazing products at mizizzi, your trusted online shopping destination for quality items and exceptional customer service.
NEXT_PUBLIC_COPYRIGHT_TEXT=© 2025 mizizzi. All rights reserved.
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy
NEXT_PUBLIC_TERMS_URL=/terms

NEXT_PUBLIC_ADMIN_EMAIL=admin@yourstore.com
TAX_AMOUNT=0.00

# Reward Points Configuration
REWARD_POINTS_THRESHOLD=3000
REWARD_POINTS_AMOUNT=5

# Loyalty Points Configuration  
LOYALTY_POINTS_ORDER_THRESHOLD=5
LOYALTY_POINTS_AMOUNT=100

# Firebase configuration for local development and production
# Get credentials from: https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# Email Service Configuration (Gmail OAuth2)
# Get credentials from: https://developers.google.com/workspace/guides/create-credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
SENDER_EMAIL_ADDRESS=your_email@gmail.com

# Cloudinary Configuration (Image Upload)
# Get credentials from: https://cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_cloudinary_api_key_here
NEXT_PUBLIC_CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Node Environment
NODE_ENV=production
